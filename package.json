{
  "name": "self-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "default": "./dist/http/index.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "default": "./dist/dashboard/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "default": "./dist/middleware/index.js"
    },
    "./multilingual": {
      "types": "./dist/multilingual/index.d.ts",
      "default": "./dist/multilingual/index.js"
    },
    "./redteam": {
      "types": "./dist/redteam/index.d.ts",
      "default": "./dist/redteam/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/fix-dist-extensions.mjs",
    "dev:http": "tsx src/http/cli.ts",
    "dev:website": "node scripts/serve-website.mjs",
    "build:website": "node scripts/build-website-single.mjs && node scripts/build-public-docs.mjs && node scripts/build-website-sitemap.mjs",
    "build:website:minified": "node scripts/build-website-minified.mjs && node scripts/build-public-docs.mjs && node scripts/build-website-sitemap.mjs",
    "start:http": "node dist/http/cli.js",
    "test": "tsx src/index.test.ts",
    "test:env": "tsx src/env.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.5",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.5.13",
    "axios": "^1.13.2",
    "body-parser": "^2.2.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.0"
  }
}
